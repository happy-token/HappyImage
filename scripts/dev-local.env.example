# Copy this file to scripts/dev-local.env.
# scripts/dev-local.env is ignored by Git.

# Local ports.
HAPPYTOKEN_API_PORT=8000
HAPPYTOKEN_WEB_PORT=3000
BACKEND_URL=http://127.0.0.1:8000

# Remote database tunnel.
# Leave HAPPYIMAGE_TUNNEL_TARGET empty if you do not need a tunnel.
HAPPYIMAGE_TUNNEL_TARGET=jp-v2
HAPPYIMAGE_TUNNEL_PORT=15432

# API storage.
# For local dev with the tunnel above, use 127.0.0.1, not host.docker.internal.
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://happyimage:password@127.0.0.1:15432/happyimage
