{
  "name": "baoyu-skills",
  "private": true,
  "description": "HappyImage AI visual content generation, web workspace, CLI, and desktop app.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happy-token/HappyImage.git"
  },
  "bugs": {
    "url": "https://github.com/happy-token/HappyImage/issues"
  },
  "homepage": "https://github.com/happy-token/HappyImage#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:gui",
    "dev:cli": "bun run --cwd packages/cli dev",
    "dev:web": "bun run --cwd packages/web-ui dev",
    "dev:gui": "bun run --cwd packages/desktop dev",
    "dev:desktop": "bun run --cwd packages/desktop dev",
    "cli": "bun packages/cli/src/bin.ts",
    "web": "bun packages/cli/src/bin.ts web --open",
    "gui": "bun packages/cli/src/bin.ts desktop",
    "desktop": "bun packages/cli/src/bin.ts desktop",
    "doctor": "bun packages/cli/src/bin.ts doctor",
    "icons": "node scripts/generate-icons.mjs",
    "icons:desktop": "node scripts/generate-icons.mjs",
    "build": "bun run --cwd packages/baoyu-chrome-cdp build && bun run --cwd packages/baoyu-md build && bun run --cwd packages/baoyu-fetch build && bun run --cwd packages/core build && bun run --cwd packages/web-ui build && bun run --cwd packages/cli build && bun run --cwd packages/desktop build",
    "build:core": "bun run --cwd packages/core build",
    "typecheck": "bun run --cwd packages/baoyu-chrome-cdp check && bun run --cwd packages/baoyu-md check && bun run --cwd packages/baoyu-fetch check && bun run --cwd packages/core check && bun run --cwd packages/web-ui check && bun run --cwd packages/cli check && bun run --cwd packages/desktop check",
    "build:cli": "bun run --cwd packages/cli build",
    "build:web": "bun run --cwd packages/web-ui build",
    "build:gui": "bun run --cwd packages/desktop build",
    "build:gui:intel": "bun run --cwd packages/desktop build:intel",
    "build:desktop": "bun run --cwd packages/desktop build",
    "build:desktop:intel": "bun run --cwd packages/desktop build:intel",
    "build:desktop:arm64": "bun run --cwd packages/desktop build:arm64",
    "build:desktop:x64": "bun run --cwd packages/desktop build:x64",
    "build:desktop:signed:local": "bun run --cwd packages/desktop build:signed:local",
    "build:desktop:dir:signed:local": "bun run --cwd packages/desktop build:dir:signed:local",
    "build:desktop:unsigned": "bun run --cwd packages/desktop build:unsigned",
    "build:desktop:dir:unsigned": "bun run --cwd packages/desktop build:dir:unsigned",
    "build:desktop:dir:intel": "bun run --cwd packages/desktop build:dir:intel",
    "pack": "bun run pack:npm && bun run pack:gui",
    "pack:npm": "bash scripts/npm-pack.sh",
    "pack:gui": "MODE=package bash scripts/desktop-release.sh",
    "pack:desktop": "MODE=package bash scripts/desktop-release.sh",
    "publish:npm": "bash scripts/npm-publish.sh",
    "publish:npm:dry": "DRY_RUN=true bash scripts/npm-publish.sh",
    "release:npm": "bash scripts/npm-publish.sh",
    "release:npm:dry": "DRY_RUN=true bash scripts/npm-publish.sh",
    "release:gui": "MODE=release bash scripts/desktop-release.sh",
    "release:desktop": "MODE=release bash scripts/desktop-release.sh",
    "release:desktop:test": "MODE=test bash scripts/desktop-release.sh",
    "release:desktop:package": "MODE=package bash scripts/desktop-release.sh",
    "release:desktop:github": "MODE=github-release bash scripts/desktop-release.sh",
    "happyimage": "bun packages/cli/src/bin.ts",
    "test:web": "bun run --cwd packages/web-ui test",
    "test:web:e2e": "bun run --cwd packages/web-ui test:e2e",
    "test": "node ./scripts/run-node-tests.mjs",
    "test:coverage": "node ./scripts/run-node-tests.mjs --experimental-test-coverage"
  },
  "devDependencies": {
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "tsx": "^4.20.5"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13"
  }
}
