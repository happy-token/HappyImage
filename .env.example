# HappyImage Configuration
# Copy this file to .env or configure via Web UI Settings page

# AI Model (required)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Image Generation Backends (at least one required)
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# DASHSCOPE_API_KEY=
# OPENROUTER_API_KEY=
# REPLICATE_API_TOKEN=
# ZAI_API_KEY=
# MINIMAX_API_KEY=
# ARK_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=

# Output
OUTPUT_DIR=~/output/happyimage

# Defaults
DEFAULT_LANGUAGE=zh
DEFAULT_ASPECT_RATIO=1:1
IMAGE_BACKEND=auto

# Publishing (Chrome profile for CDP)
# BAOYU_CHROME_PROFILE_DIR=

# Skills lookup (optional)
# When set, overrides bundled skills and user-config skills
