{
  "name": "@happytokenai/happyimage-web",
  "version": "0.2.0",
  "description": "Visual workspace for running baoyu-skills content generation workflows.",
  "license": "MIT",
  "type": "module",
  "main": "./server/index.ts",
  "types": "./server/index.ts",
  "exports": {
    ".": {
      "types": "./server/index.ts",
      "default": "./server/index.ts"
    }
  },
  "files": [
    "dist/assets",
    "dist/index.html",
    "dist/logo.svg",
    "server",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happy-token/HappyImage.git",
    "directory": "packages/web-ui"
  },
  "bugs": {
    "url": "https://github.com/happy-token/HappyImage/issues"
  },
  "homepage": "https://github.com/happy-token/HappyImage#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"bun run server/index.ts\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "bun run server/index.ts",
    "test": "bun test tests/ --path-ignore-patterns \"**/e2e.spec.cjs\" && echo '---' && echo 'Run API tests separately: bun test tests/api.test.ts'",
    "test:e2e": "node ../../node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@happytokenai/happyimage-core": "^0.2.0",
    "dompurify": "^3.4.5",
    "hono": "^4.7.0",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
